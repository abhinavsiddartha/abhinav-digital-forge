{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Correct module resolution for Vite */
    "moduleResolution": "bundler",

    /* Clean build setup */
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Dev-friendly (can tighten later) */
    "strict": false,

    /* Path alias */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}